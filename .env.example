# ============================================================
# Trading Bot - Environment Configuration
# ============================================================

# ============================================================
# Discord Bot Configuration (REQUIRED)
# ============================================================
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_IDS=123456789,987654321
DISCORD_GUILD_ID=123456789

# Optional OpenClaw fallback. If DISCORD_BOT_TOKEN or DISCORD_CHANNEL_IDS
# are not set, Consolidation can read them from your local OpenClaw config.
CONSOLIDATION_USE_OPENCLAW_DISCORD=true
OPENCLAW_HOME=C:\Users\Lite OS\.openclaw

# ============================================================
# Database Configuration
# ============================================================
MONGO_URL=mongodb://tradebot:tradebot123@localhost:27017
MONGO_USER=tradebot
MONGO_PASSWORD=tradebot123
DB_NAME=tradebot
DATABASE_PATH=./data/tradebot.db

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Broker Configuration
# ========================================

# Interactive Brokers
IBKR_GATEWAY_URL=https://localhost:5000
IBKR_ACCOUNT_ID=your-account-id

# Alpaca
ALPACA_API_KEY=your-alpaca-key
ALPACA_API_SECRET=your-alpaca-secret
ALPACA_PAPER=true

# TD Ameritrade
TDA_API_KEY=your-tda-key
TDA_ACCOUNT_ID=your-account-id

# Tradier
TRADIER_API_KEY=your-tradier-key
TRADIER_ACCOUNT_ID=your-account-id
TRADIER_MODE=paper

# ============================================================
# Security
# ============================================================
SECRET_KEY=change-this-to-a-random-string-at-least-32-chars
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ============================================================
# Server Configuration
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ============================================================
# Sentinel Edge Integration
# ============================================================
EDGE_HOST=sentinel-edge
EDGE_PORT=8000
EDGE_API_KEY=
SIMULATION_ENGINE_REPLAY_URL=http://127.0.0.1:9200/api/consolidation/replay/events

# ============================================================
# Monitoring & Observability
# ============================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
PROMETHEUS_ENABLED=true

# ============================================================
# Docker Settings
# ============================================================
COMPOSE_PROJECT_NAME=tradebot
TZ=America/New_York

# ============================================================
# Trading Defaults
# ============================================================
DEFAULT_QUANTITY=5
MAX_POSITION_SIZE=1000
PRICE_BUFFER=2
SIMULATION_MODE=true
