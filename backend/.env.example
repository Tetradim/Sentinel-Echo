# Trading Bot Environment Template
# Copy this to .env and fill in your values

# ============= DISCORD BOT =============
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Channel IDs to listen on (comma-separated)
DISCORD_CHANNEL_IDS=123456789,987654321

# ============= DATABASE =============
# Use SQLite (true) or MongoDB (false)
USE_SQLITE=true

# SQLite path
DATABASE_PATH=tradebot.db

# OR MongoDB (if USE_SQLITE=false)
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=tradebot

# ============= BROKER (IBKR) =============
# IBKR Gateway URL (local IBKR app)
IBKR_GATEWAY_URL=https://localhost:5000

# IBKR account ID (from IBKR app)
IBKR_ACCOUNT_ID=your-account-id

# ============= BROKER (Alpaca) - Optional =============
# Get from https://app.alpaca.markets
# ALPACA_API_KEY=your-api-key
# ALPACA_SECRET_KEY=your-secret-key
# ALPACA_PAPER=true  # Use paper trading

# ============= TRADING SETTINGS =============
# Default quantity per trade
DEFAULT_QUANTITY=1

# Max position size per trade ($)
MAX_POSITION_SIZE=1000

# Max positions per ticker
MAX_POSITIONS_PER_TICKER=3

# Max total open positions
MAX_OPEN_POSITIONS=10

# ============= PRICE BUFFER =============
# Apply buffer to entry price (safety margin)
USE_PRICE_BUFFER=true

# Buffer percentage (e.g., 3 = 3% below entry)
PRICE_BUFFER_PERCENTAGE=3

# ============= BRACKET ORDERS =============
# Enable bracket orders (profit target + stop loss)
ENABLE_BRACKET_ORDERS=true

# Default profit target (%)
DEFAULT_PROFIT_TARGET=50

# Default stop loss (%)
DEFAULT_STOP_LOSS=30

# ============= TRAILING STOP =============
# Enable trailing stop
ENABLE_TRAILING_STOP=true

# Trailing stop percentage
TRAILING_PERCENTAGE=25

# ============= SIMULATION =============
# Run in simulation mode (no real trades)
SIMULATION_MODE=true

# ============= SERVER =============
# API host/port
# Keep 127.0.0.1 for desktop mode. If you bind to 0.0.0.0, API_KEY is required.
HOST=127.0.0.1
PORT=8000

# API key required for non-local binds. Send as X-API-Key.
API_KEY=change-this-to-a-strong-random-api-key

# Broker credential encryption key.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_KEY=change-this-to-a-64-character-hex-string

# ============= LOGGING =============
LOG_LEVEL=INFO

# ============= auto_shutdown =============
# Auto shutdown on losses
AUTO_SHUTDOWN_ENABLED=false
MAX_CONSECUTIVE_LOSSES=3
MAX_DAILY_LOSSES=5
MAX_DAILY_LOSS_AMOUNT=500
