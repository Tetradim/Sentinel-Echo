{
  "manifest_version": 3,
  "name": "Local Discord Alert Bridge",
  "description": "Observes selected Discord Web channels in Chrome and forwards visible alert messages to local trading bots.",
  "version": "0.2.1",
  "permissions": ["storage", "alarms", "scripting", "tabs"],
  "host_permissions": [
    "https://discord.com/*",
    "https://*.discord.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*", "https://*.discord.com/*"],
      "js": ["bridge_config.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Discord Alert Bridge",
    "default_popup": "popup.html"
  }
}
